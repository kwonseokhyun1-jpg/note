{
  "$schema": "https://openapi.vercel.com/vercel.json",
  "framework": null,
  "installCommand": "npm ci --prefix mtg",
  "buildCommand": "npm run build --prefix mtg",
  "outputDirectory": "mtg/dist",
  "functions": {
    "api/**/*.ts": {
      "maxDuration": 30
    }
  },
  "rewrites": [
    {
      "source": "/api/reddit/:path*",
      "destination": "https://www.reddit.com/:path*"
    },
    {
      "source": "/api/tcgplayer/:path*",
      "destination": "/api/tcgplayer?path=:path*"
    },
    {
      "source": "/api/groq/chat/completions",
      "destination": "/api/groq"
    },
    {
      "source": "/((?!api/).*)",
      "destination": "/index.html"
    }
  ]
}
